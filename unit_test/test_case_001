import 'package:flutter/material.dart';
import 'package:flutter_test/flutter_test.dart';
import 'package:breathe_better/pages/login_page.dart';

void main() {
  group('LoginPage Invalid Email Format Tests', () {
    testWidgets('Student enters invalid email format during login - Login fails with "Invalid email format" error message', (WidgetTester tester) async {
      // Arrange: Build the LoginPage widget
      await tester.pumpWidget(
        MaterialApp(
          home: LoginPage(),
        ),
      );

      // Find the email and password text fields
      final emailField = find.byKey(Key('login_email'));
      final passwordField = find.byKey(Key('login_password'));
      final loginButton = find.text('Login');

      // Verify widgets are present
      expect(emailField, findsOneWidget);
      expect(passwordField, findsOneWidget);
      expect(loginButton, findsOneWidget);

      // Test Case 1: Email without @ symbol
      await tester.enterText(emailField, 'invalidemailformat');
      await tester.enterText(passwordField, 'validPassword123');
      await tester.tap(loginButton);
      await tester.pump();

      // Assert: Should show "Invalid email format" error
      expect(find.text('Invalid email format'), findsOneWidget);

      // Clear the fields for next test
      await tester.enterText(emailField, '');
      await tester.pump();

      // Test Case 2: Email with missing domain
      await tester.enterText(emailField, 'user@');
      await tester.tap(loginButton);
      await tester.pump();

      // Assert: Should show "Invalid email format" error
      expect(find.text('Invalid email format'), findsOneWidget);

      // Clear the fields for next test
      await tester.enterText(emailField, '');
      await tester.pump();

      // Test Case 3: Email with invalid characters
      await tester.enterText(emailField, 'user@domain@invalid.com');
      await tester.tap(loginButton);
      await tester.pump();

      // Assert: Should show "Invalid email format" error
      expect(find.text('Invalid email format'), findsOneWidget);

      // Clear the fields for next test
      await tester.enterText(emailField, '');
      await tester.pump();

      // Test Case 4: Email with missing top-level domain
      await tester.enterText(emailField, 'user@domain');
      await tester.tap(loginButton);
      await tester.pump();

      // Assert: Should show "Invalid email format" error
      expect(find.text('Invalid email format'), findsOneWidget);

      // Clear the fields for next test
      await tester.enterText(emailField, '');
      await tester.pump();

      // Test Case 5: Email with spaces
      await tester.enterText(emailField, 'user name@domain.com');
      await tester.tap(loginButton);
      await tester.pump();

      // Assert: Should show "Invalid email format" error
      expect(find.text('Invalid email format'), findsOneWidget);

      // Clear the fields for next test
      await tester.enterText(emailField, '');
      await tester.pump();

      // Test Case 6: Empty email field
      await tester.enterText(emailField, '');
      await tester.enterText(passwordField, 'validPassword123');
      await tester.tap(loginButton);
      await tester.pump();

      // Assert: Should show "Email field is required" error
      expect(find.text('Email field is required'), findsOneWidget);

      // Test Case 7: Valid email format (should not show validation error)
      await tester.enterText(emailField, 'valid.email@domain.com');
      await tester.enterText(passwordField, 'validPassword123');
      await tester.tap(loginButton);
      await tester.pump();

      // Assert: Should NOT show email validation errors
      expect(find.text('Invalid email format'), findsNothing);
      expect(find.text('Email field is required'), findsNothing);
    });

    testWidgets('Email validation regex test - covers all invalid email scenarios', (WidgetTester tester) async {
      // Build the widget
      await tester.pumpWidget(
        MaterialApp(
          home: LoginPage(),
        ),
      );

      final emailField = find.byKey(Key('login_email'));
      final loginButton = find.text('Login');

      // List of invalid email formats to test
      final invalidEmails = [
        'plainaddress',           // No @ symbol
        '@missinglocal.com',      // Missing local part
        'missing@.com',           // Missing domain name
        'missing@domain',         // Missing TLD
        'spaces in@email.com',    // Spaces in local part
        'user@spaces in.com',     // Spaces in domain
        'user..double.dot@domain.com', // Double dots
        'user@domain..com',       // Double dots in domain
        '.user@domain.com',       // Starting with dot
        'user.@domain.com',       // Ending with dot
        'user@',                  // Missing domain completely
        'user@domain.',           // TLD missing
        'user@.domain.com',       // Domain starting with dot
        'user@domain..com',       // Double dot in domain
        'user@domain.c',          // TLD too short
        'user name@domain.com',   // Space in local part
        'user@domain .com',       // Space in domain
        'user@@domain.com',       // Double @
        'user@domain@extra.com',  // Multiple @
        '',                       // Empty string
      ];

      for (String invalidEmail in invalidEmails) {
        // Clear previous text
        await tester.enterText(emailField, '');
        await tester.pump();

        // Enter invalid email
        await tester.enterText(emailField, invalidEmail);
        await tester.tap(loginButton);
        await tester.pump();

        // Check for appropriate error message
        if (invalidEmail.isEmpty) {
          expect(find.text('Email field is required'), findsOneWidget,
              reason: 'Empty email should show "Email field is required"');
        } else {
          expect(find.text('Invalid email format'), findsOneWidget,
              reason: 'Invalid email "$invalidEmail" should show "Invalid email format"');
        }
      }
    });

    testWidgets('Valid email formats should pass validation', (WidgetTester tester) async {
      // Build the widget
      await tester.pumpWidget(
        MaterialApp(
          home: LoginPage(),
        ),
      );

      final emailField = find.byKey(Key('login_email'));
      final passwordField = find.byKey(Key('login_password'));
      final loginButton = find.text('Login');

      // List of valid email formats
      final validEmails = [
        'user@domain.com',
        'user.name@domain.com',
        'user+tag@domain.com',
        'user123@domain123.com',
        'user@subdomain.domain.com',
        'a@b.co',
        'test.email@domain.co.uk',
        'user_name@domain-name.com',
      ];

      for (String validEmail in validEmails) {
        // Clear previous text
        await tester.enterText(emailField, '');
        await tester.enterText(passwordField, '');
        await tester.pump();

        // Enter valid email and password
        await tester.enterText(emailField, validEmail);
        await tester.enterText(passwordField, 'testPassword123');
        await tester.tap(loginButton);
        await tester.pump();

        // Check that no email validation errors appear
        expect(find.text('Invalid email format'), findsNothing,
            reason: 'Valid email "$validEmail" should not show validation error');
        expect(find.text('Email field is required'), findsNothing,
            reason: 'Valid email "$validEmail" should not show required field error');
      }
    });
  });
}
